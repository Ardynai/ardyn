{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ardyn.ai/task.schema.json",
  "title": "ARDYN Task",
  "description": "A task request submitted to an ARDYN runtime.",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "objective", "mode", "requestedCapabilities"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:-]{2,127}$"
    },
    "objective": {
      "type": "string",
      "minLength": 1,
      "maxLength": 4000
    },
    "mode": {
      "type": "string",
      "enum": ["plan", "dry-run"]
    },
    "requestedCapabilities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9-]*(\\.[a-z][a-z0-9-]*)*$"
      }
    },
    "constraints": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "requireHumanApproval": {
          "type": "boolean"
        },
        "allowNetwork": {
          "type": "boolean"
        },
        "maxSteps": {
          "type": "integer",
          "minimum": 1,
          "maximum": 1000
        },
        "workspaceRoot": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "inputs": {
      "type": "object",
      "additionalProperties": true
    },
    "metadata": {
      "type": "object",
      "additionalProperties": {
        "anyOf": [
          { "type": "string" },
          { "type": "number" },
          { "type": "boolean" },
          { "type": "null" }
        ]
      }
    }
  }
}
