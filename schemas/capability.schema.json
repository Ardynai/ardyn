{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ardyn.ai/capability.schema.json",
  "title": "ARDYN Capability",
  "description": "A declared capability exposed by an ARDYN manifest.",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "kind", "description", "permissions"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*(\\.[a-z][a-z0-9-]*)*$",
      "minLength": 3,
      "maxLength": 96
    },
    "kind": {
      "type": "string",
      "enum": [
        "adapter",
        "browser",
        "desktop",
        "mcp-client",
        "mcp-server",
        "memory",
        "model-provider",
        "tool",
        "workflow"
      ]
    },
    "description": {
      "type": "string",
      "minLength": 1,
      "maxLength": 280
    },
    "tags": {
      "type": "array",
      "maxItems": 32,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9-]*(\\.[a-z][a-z0-9-]*)*$",
        "minLength": 3,
        "maxLength": 96
      }
    },
    "permissions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["scope", "access"],
        "properties": {
          "scope": {
            "type": "string",
            "enum": [
              "browser",
              "credentials",
              "desktop",
              "filesystem",
              "memory",
              "network",
              "process",
              "provider",
              "registry"
            ]
          },
          "access": {
            "type": "string",
            "enum": ["read", "write", "connect", "admin"]
          },
          "reason": {
            "type": "string",
            "minLength": 1,
            "maxLength": 240
          }
        }
      }
    }
  }
}
