{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ardyn.ai/ardyn.manifest.schema.json",
  "title": "ARDYN Manifest",
  "description": "Top-level manifest for an ARDYN harness instance or adapter package.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "name", "version", "runtime", "capabilities"],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "0.1.0"
    },
    "name": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]{1,62}[a-z0-9]$"
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(-[0-9A-Za-z.-]+)?$"
    },
    "description": {
      "type": "string",
      "minLength": 1,
      "maxLength": 280
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": ["host", "core"],
      "properties": {
        "host": {
          "type": "string",
          "enum": ["rust"]
        },
        "core": {
          "type": "string",
          "enum": ["typescript"]
        },
        "entrypoint": {
          "type": "string",
          "minLength": 1,
          "maxLength": 240
        }
      }
    },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "https://schemas.ardyn.ai/capability.schema.json"
      }
    },
    "adapters": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["enabled", "external"],
        "properties": {
          "enabled": {
            "type": "boolean"
          },
          "external": {
            "type": "boolean"
          },
          "endpoint": {
            "type": "string",
            "minLength": 1,
            "maxLength": 240
          },
          "notes": {
            "type": "string",
            "maxLength": 400
          }
        }
      }
    },
    "policies": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "defaultTaskMode": {
          "type": "string",
          "enum": ["plan", "dry-run"]
        },
        "requiresApprovalFor": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "browser",
              "credentials",
              "desktop",
              "filesystem",
              "network",
              "process",
              "provider",
              "registry"
            ]
          }
        }
      }
    }
  }
}
