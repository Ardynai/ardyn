{
  "name": "ardyn",
  "version": "0.1.0",
  "private": true,
  "description": "ARDYN is an open-source AI harness/framework.",
  "type": "module",
  "scripts": {
    "test": "node --test tests/*.test.mjs",
    "test:schemas": "node --test tests/schema-validation.test.mjs tests/session-event-schema.test.mjs tests/session-transcript-schema.test.mjs",
    "report:phase-status": "node scripts/report-phase-status.mjs"
  },
  "workspaces": [
    "packages/*",
    "packages/adapters/*",
    "apps/*"
  ],
  "devDependencies": {
    "ajv": "^8.17.1"
  },
  "engines": {
    "node": ">=20"
  }
}

